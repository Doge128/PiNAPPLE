    <div class="card-title">SSID List (one per line, max 50)</div>
    <textarea id="bf-ssids" rows="12"
      style="width:100%;background:var(--bg);border:1px solid var(--bdr);color:var(--txt);
             padding:10px;border-radius:8px;font-size:0.8rem;font-family:monospace;margin-top:8px;resize:vertical"
      placeholder="Free WiFi&#10;Starbucks WiFi&#10;xfinitywifi&#10;Hotel Guest&#10;ATT Wi-Fi">Free WiFi
Starbucks WiFi
xfinitywifi
Hotel Guest WiFi
ATT Wi-Fi
CableWiFi
XFINITY
TWC WiFi Passpoint
Airport Free WiFi
_The Coffee Bean_
hhonors
Marriott_GUEST
Boingo Hotspot
Google Starbucks
optimumwifi</textarea>
    <div style="display:flex;gap:8px;margin-top:12px">
      <button class="btn btn-danger" onclick="startFlood()" id="bf-start">&#128225; Start Flood</button>
      <button class="btn btn-outline" onclick="stopFlood()" id="bf-stop">&#9632; Stop</button>
    </div>
  </div>
  <div class="card">
    <div class="card-title">Status</div>
    <div id="bf-status" style="margin-top:8px;font-size:0.85rem;color:var(--dim)">Idle</div>
    <div id="bf-active-ssids" style="margin-top:12px"></div>
  </div>
  </div>
</div>

<!-- TRACKER TAB -->
<div id="pane-tracker" class="tab-pane" style="display:none">
  <div class="sh"><span class="st">All Devices Seen on wlan1 ({nt} total)</span>
    <span style="font-size:0.75rem;color:var(--dim)">Auto-refresh 10s</span></div>
  <div class="twrap"><table>
    <thead><tr><th>MAC Address</th><th>First Seen</th><th>Last Seen</th><th>Packet Types</th><th>Probed SSIDs</th><th>Pkts</th></tr></thead>
    <tbody id="tracker-tbody">{tracker_rows}</tbody>
  </table></div>
</div>
""".format(
        np=len(probes), nt=len(tracker),
        probe_rows=probe_rows, tracker_rows=tracker_rows,
        net_opts=net_opts, net_opts2=net_opts,
    )

    js = r"""<script>
function showTab(name) {
  document.querySelectorAll('.tab-pane').forEach(p => p.style.display='none');
  document.getElementById('pane-'+name).style.display='';
  document.querySelectorAll('.tab-pane ~ * button, [id^="tab-"]').forEach(b => b.classList.remove('btn-acc'));
  const btn = document.getElementById('tab-'+name);
  if (btn) { btn.classList.remove('btn-outline'); btn.classList.add('btn-acc'); }
}
showTab('probes');

function fillBssid(v) { if(v) document.getElementById('da-bssid').value=v; }
function fillHsBssid(v) {
  if (!v) return;
  document.getElementById('hs-bssid').value = v;
  // try to fill channel from recon data
}

async function fireDeauth() {
  const bssid = document.getElementById('da-bssid').value.trim();
  const client = document.getElementById('da-client').value.trim() || 'FF:FF:FF:FF:FF:FF';
  const count = parseInt(document.getElementById('da-count').value);
  if (!bssid) { alert('Enter a BSSID'); return; }
  const out = document.getElementById('da-output');
  out.textContent = 'Sending...';
  const r = await api('/api/wlan1/deauth', 'POST', {bssid, client, count});
  out.textContent = r.output || (r.error || 'Error');
  out.style.color = r.ok ? 'var(--grn)' : 'var(--red)';
}

let hsJobId = null;
let hsPoll = null;

async function startHandshake() {
  const bssid = document.getElementById('hs-bssid').value.trim();
  const channel = document.getElementById('hs-channel').value;
  const client = document.getElementById('hs-client').value.trim() || 'FF:FF:FF:FF:FF:FF';
  if (!bssid) { alert('Enter a BSSID'); return; }
  document.getElementById('hs-btn').textContent = 'Running...';
  document.getElementById('hs-btn').disabled = true;
  const st = document.getElementById('hs-status');
  st.style.display = '';
  st.style.color = 'var(--txt)';
  st.textContent = '[*] Starting capture on ' + bssid + ' ch' + channel + '...\n';
  const r = await api('/api/wlan1/handshake', 'POST', {bssid, channel, client});
  if (!r.ok) { st.textContent = 'Error: ' + r.error; return; }
  hsJobId = r.job_id;
  hsPoll = setInterval(async () => {
    const s = await api('/api/wlan1/handshake/' + hsJobId, 'GET');
    st.textContent = s.output || '';
    if (s.status !== 'running') {
      clearInterval(hsPoll);
      document.getElementById('hs-btn').textContent = 'Start Capture';
      document.getElementById('hs-btn').disabled = false;
      if (s.status === 'success' && s.pcap) {
        st.textContent += '\n[+] HANDSHAKE CAPTURED!\n';
        st.style.color = 'var(--grn)';
        const dl = document.createElement('a');
        dl.href = '/api/wlan1/pcap/' + s.pcap;
        dl.textContent = 'Download ' + s.pcap;
        dl.className = 'btn btn-acc';
        dl.style.marginTop = '8px';
        dl.style.display = 'inline-flex';
        st.after(dl);
      } else {
        st.style.color = 'var(--warn)';
      }
    }
  }, 2000);
}

async function startFlood() {
  const raw = document.getElementById('bf-ssids').value;
  const ssids = raw.split('\n').map(s=>s.trim()).filter(Boolean);
  if (!ssids.length) { alert('Enter at least one SSID'); return; }
  const r = await api('/api/wlan1/beacon-flood/start', 'POST', {ssids});
  const st = document.getElementById('bf-status');
  if (r.ok) {
    st.textContent = 'Flooding ' + r.ssid_count + ' SSIDs (PID ' + r.pid + ')';
    st.style.color = 'var(--red)';
  } else {
    st.textContent = 'Error: ' + r.error;
  }
  updateBeaconStatus();
}

async function stopFlood() {
  const r = await api('/api/wlan1/beacon-flood/stop', 'POST');
  document.getElementById('bf-status').textContent = 'Stopped.';
  document.getElementById('bf-status').style.color = 'var(--dim)';
  document.getElementById('bf-active-ssids').innerHTML = '';
}

async function updateBeaconStatus() {
  const r = await fetch('/api/wlan1/beacon-flood/status');
  const d = await r.json();
  const st = document.getElementById('bf-status');
  if (d.running) {
    st.textContent = 'ACTIVE — flooding ' + (d.ssids||[]).length + ' SSIDs (PID ' + d.pid + ')';
    st.style.color = 'var(--red)';
    document.getElementById('bf-active-ssids').innerHTML =
      '<div style="font-size:0.75rem;color:var(--dim);margin-top:4px">' +
      (d.ssids||[]).map(s=>'<span class="badge bb" style="margin:2px">'+s+'</span>').join(' ') + '</div>';
  }
}
updateBeaconStatus();

// Auto-refresh probes
async function refreshProbes() {
  const r = await fetch('/api/probes');
  const data = await r.json();
  const t = document.getElementById('probe-tbody');
  if (!data.length) {
    t.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--dim)">No probes yet</td></tr>';
    return;
  }
  t.innerHTML = data.map(p => '<tr><td><code style="font-size:0.75rem">'+p.mac+'</code></td><td><strong>'+p.ssid+'</strong></td><td style="font-size:0.75rem;color:var(--dim)">'+p.first_seen+'</td><td style="font-size:0.75rem;color:var(--dim)">'+p.last_seen+'</td><td style="text-align:center">'+p.count+'</td></tr>').join('');
}
setInterval(refreshProbes, 5000);

// Auto-refresh tracker
const ptColors = {'probe-req':'bb','beacon':'bg','data':'bw','deauth':'br','mgmt':''};
async function refreshTracker() {
  const r = await fetch('/api/tracker');
  const data = await r.json();
  const t = document.getElementById('tracker-tbody');
  if (!data.length) {
    t.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--dim)">No devices seen yet</td></tr>';
    return;
  }
  t.innerHTML = data.slice(0,100).map(d => {
    const types = Object.entries(d.packet_types||{}).sort((a,b)=>b[1]-a[1]).slice(0,4)
      .map(([k])=>'<span class="badge '+(ptColors[k]||'')+'">'+k+'</span>').join(' ');
    return '<tr><td><code style="font-size:0.75rem">'+d.mac+'</code></td><td style="font-size:0.75rem;color:var(--dim)">'+d.first_seen+'</td><td style="font-size:0.75rem;color:var(--dim)">'+d.last_seen+'</td><td>'+types+'</td><td style="font-size:0.75rem;color:var(--acc)">'+(d.ssids||[]).slice(0,3).join(', ')+'</td><td style="text-align:center">'+(d.count||0)+'</td></tr>';
  }).join('');
}
setInterval(refreshTracker, 10000);
</script>"""

    return page('WLAN1 Attacks', content, 'wl', js)


if __name__ == '__main__':
    os.makedirs('/var/log/pinapple', exist_ok=True)
    os.makedirs('/etc/pinapple', exist_ok=True)
    app.run(host='0.0.0.0', port=8080, debug=False)
