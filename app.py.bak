    # Tracker table rows
    def pt_badges(pt_dict):
        colors = {'probe-req':'bb','beacon':'bg','data':'bw','deauth':'br','mgmt':'','assoc-req':'bb'}
        return ' '.join('<span class="badge {}">{}</span>'.format(
            colors.get(k,''), k) for k,v in sorted(pt_dict.items(), key=lambda x: -x[1])[:4])

