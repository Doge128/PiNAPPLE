#!/usr/bin/env python3
"""PiNAPPLE Dashboard - WiFi Auditing Platform"""
import os, json, subprocess, csv, io, datetime, glob
from functools import wraps
from flask import Flask, request, jsonify, redirect, Response
from werkzeug.security import check_password_hash, generate_password_hash

app = Flask(__name__)

CONFIG_FILE = '/etc/pinapple/config.json'
CREDS_LOG = '/var/log/pinapple/creds.log'
SCAN_JSON = '/var/log/pinapple/scan.json'
LEASES_FILE = '/var/lib/misc/dnsmasq.leases'
LOG_DIR = '/var/log/pinapple'
HOSTAPD_CONF = '/etc/hostapd/hostapd.conf'
FLAG_INTERNET = '/etc/pinapple/internet_enabled'
FLAG_DNS = '/etc/pinapple/dns_hijack_enabled'
FLAG_PORTAL = '/etc/pinapple/portal_redirect_enabled'
ACTIVE_PORTAL = '/opt/pinapple/portal/index.html'

def load_config():
    defaults = {
        'username': 'admin',
        'password_hash': generate_password_hash('pinapple'),
        'portal_type': 'creds',
        'mac_randomize': True
    }
    try:
        with open(CONFIG_FILE) as f:
            cfg = json.load(f)
            for k, v in defaults.items():
                if k not in cfg:
                    cfg[k] = v
            return cfg
    except:
        return defaults

def save_config(cfg):
    os.makedirs('/etc/pinapple', exist_ok=True)
    with open(CONFIG_FILE, 'w') as f:
        json.dump(cfg, f, indent=2)

def require_auth(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        auth = request.authorization
        cfg = load_config()
        if not auth or auth.username != cfg['username'] or \
           not check_password_hash(cfg['password_hash'], auth.password):
            return Response('Authentication required', 401,
                          {'WWW-Authenticate': 'Basic realm="PiNAPPLE"'})
        return f(*args, **kwargs)
    return decorated

def service_status(name):
    r = subprocess.run(['systemctl', 'is-active', name], capture_output=True, text=True)
    return r.stdout.strip() == 'active'

def monitor_mode_active():
    r = subprocess.run(['iw', 'dev', 'wlan1', 'info'], capture_output=True, text=True)
    return 'type monitor' in r.stdout

def get_clients():
    clients = []
    try:
        with open(LEASES_FILE) as f:
            for line in f:
                parts = line.strip().split()
                if len(parts) >= 4:
                    clients.append({
                        'expires': datetime.datetime.fromtimestamp(int(parts[0])).isoformat(),
                        'mac': parts[1], 'ip': parts[2],
                        'hostname': parts[3] if parts[3] != '*' else 'unknown'
                    })
    except:
        pass
    return clients

def get_recon():
    try:
        with open(SCAN_JSON) as f:
            return json.load(f)
    except:
        return []

def get_creds():
    entries = []
    try:
        with open(CREDS_LOG) as f:
            for line in f:
                try:
                    entries.append(json.loads(line.strip()))
                except:
                    pass
    except:
        pass
    return entries

def read_hostapd_conf():
    cfg = {}
    try:
        with open(HOSTAPD_CONF) as f:
            for line in f:
                line = line.strip()
                if '=' in line and not line.startswith('#'):
                    k, v = line.split('=', 1)
                    cfg[k.strip()] = v.strip()
    except:
        pass
    return cfg

def write_hostapd_conf(ssid, channel, mode, txpower):
    pwd_line = ''
    if mode == 'wpa2':
        pwd_line = '\nwpa=2\nwpa_passphrase=pinapple123\nwpa_key_mgmt=WPA-PSK\nrsn_pairwise=CCMP'
    conf = "interface=wlan0\ndriver=nl80211\nssid={}\nhw_mode=g\nchannel={}\nieee80211n=1\n".format(ssid, channel)
    conf += "ht_capab=[HT40+][HT40-][SHORT-GI-20][SHORT-GI-40][DSSS_CCK-40]\nwmm_enabled=1\nauth_algs=1\nignore_broadcast_ssid=0"
    conf += pwd_line + "\n"
    with open(HOSTAPD_CONF, 'w') as f:
        f.write(conf)

